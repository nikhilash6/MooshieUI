#!/usr/bin/env bash
# GlassWorm pre-commit hook
# Blocks commits if any of the four GlassWorm indicators are detected.
# Install via:  bash scripts/setup-hooks.sh

set -euo pipefail

RED='\033[31m'
GREEN='\033[32m'
BOLD='\033[1m'
RESET='\033[0m'

PASS="${GREEN}PASS${RESET}"
FAIL="${RED}${BOLD}FAIL${RESET}"
MARKER_TOKEN="lzcd""rtfxyqiplpd"

any_failed=0

echo "── GlassWorm pre-commit scan ─────────────────────────────────"

# ── Collect staged files ──────────────────────────────────────────
# Full list used for Unicode + eval checks
staged_files=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

# ── 1. Marker scan (full repo) ───────────────────────────────────
echo ""
echo "Check 1: Marker variable scan (full repo)"
if grep -rn --include="*" "$MARKER_TOKEN" . \
        --exclude-dir=.git \
        --exclude-dir=node_modules \
        --exclude-dir=__pycache__ \
        --exclude-dir=.venv \
        --exclude-dir=venv \
        2>/dev/null | grep -q .; then
    echo -e "${FAIL}: GlassWorm marker token found in repo:"
    grep -rn --include="*" "$MARKER_TOKEN" . \
        --exclude-dir=.git \
        --exclude-dir=node_modules \
        --exclude-dir=__pycache__
    any_failed=1
else
    echo -e "${PASS}: No marker variable found."
fi

# ── 2. Unicode steganography scan (staged files only) ────────────
echo ""
echo "Check 2: Unicode variation-selector steganography (staged files)"

unicode_hits=""
for f in $staged_files; do
    ext="${f##*.}"
    case "$ext" in
        py|js|ts|svelte|rs) ;;
        *) continue ;;
    esac
    [[ -f "$f" ]] || continue

    # Scan for variation-selector byte sequences using Python
    result=$(python3 - "$f" <<'PYEOF'
import sys, os

path = sys.argv[1]
try:
    data = open(path, "rb").read()
except OSError:
    sys.exit(0)

hits = []
i = 0
while i < len(data):
    if (i + 2 < len(data) and data[i] == 0xEF and data[i+1] == 0xB8
            and 0x80 <= data[i+2] <= 0x8F):
        cp = 0xFE00 + (data[i+2] - 0x80)
        hits.append(f"  {path}  byte offset {i}  codepoint {hex(cp)}")
        i += 3
        continue
    if (i + 3 < len(data) and data[i] == 0xF3 and data[i+1] == 0xA0
            and 0x84 <= data[i+2] <= 0x87
            and (data[i+2] != 0x87 or data[i+3] <= 0xAF)):
        cp = 0xE0000 + ((data[i+2] - 0x80) << 6) + (data[i+3] - 0x80)
        hits.append(f"  {path}  byte offset {i}  codepoint {hex(cp)}")
        i += 4
        continue
    i += 1

for h in hits:
    print(h)
PYEOF
)
    if [[ -n "$result" ]]; then
        unicode_hits+="$result"$'\n'
    fi
done

if [[ -n "$unicode_hits" ]]; then
    echo -e "${FAIL}: Invisible Unicode variation selectors found in staged files:"
    echo "$unicode_hits"
    any_failed=1
else
    echo -e "${PASS}: No Unicode steganography payloads found in staged files."
fi

# ── 3. Git date-tampering scan (full history) ────────────────────
echo ""
echo "Check 3: Git committer/author date discrepancy (full history)"

tampered=$(git log --format="%H %ai %ci" --all | python3 - <<'PYEOF'
import sys
from datetime import datetime, timezone, timedelta
import re

DT_RE = re.compile(r"(\d{4}-\d{2}-\d{2})\s+(\d{2}:\d{2}:\d{2})\s+([+-]\d{4})")

def parse_dt(date_part, time_part, tz_part):
    dt = datetime.strptime(date_part + " " + time_part, "%Y-%m-%d %H:%M:%S")
    sign = 1 if tz_part[0] == "+" else -1
    h, mn = int(tz_part[1:3]), int(tz_part[3:5])
    return dt.replace(tzinfo=timezone.utc) - timedelta(hours=h*sign, minutes=mn*sign)

for line in sys.stdin:
    parts = line.strip().split()
    if len(parts) < 7:
        continue
    sha = parts[0]
    a = parse_dt(parts[1], parts[2], parts[3])
    c = parse_dt(parts[4], parts[5], parts[6])
    diff = (c - a).total_seconds()
    if diff > 3600:
        print(f"  {sha[:12]}  committer is {diff/3600:.1f}h ahead of author")
PYEOF
)

if [[ -n "$tampered" ]]; then
    echo -e "${FAIL}: Suspicious author/committer date gaps found:"
    echo "$tampered"
    any_failed=1
else
    echo -e "${PASS}: No date-tampering detected in git history."
fi

# ── 4. Obfuscated eval scan (staged files only) ──────────────────
echo ""
echo "Check 4: Obfuscated eval() calls (staged files)"

eval_hits=""
for f in $staged_files; do
    ext="${f##*.}"
    case "$ext" in
        py|js|ts|svelte) ;;
        *) continue ;;
    esac
    [[ -f "$f" ]] || continue

    result=$(python3 - "$f" <<'PYEOF'
import sys, re

path = sys.argv[1]
EVAL_RE = re.compile(
    r"eval\s*\((?:.{0,120}?)(?:decode|atob|fromCharCode|Buffer\.from|base64)",
    re.DOTALL
)
try:
    lines = open(path, "r", encoding="utf-8", errors="replace").readlines()
except OSError:
    sys.exit(0)

for lineno, line in enumerate(lines, 1):
    if EVAL_RE.search(line):
        print(f"  {path}:{lineno}  {line.strip()[:120]}")
PYEOF
)
    if [[ -n "$result" ]]; then
        eval_hits+="$result"$'\n'
    fi
done

if [[ -n "$eval_hits" ]]; then
    echo -e "${FAIL}: Obfuscated eval() calls found in staged files:"
    echo "$eval_hits"
    any_failed=1
else
    echo -e "${PASS}: No obfuscated eval() calls found in staged files."
fi

# ── Result ────────────────────────────────────────────────────────
echo ""
echo "══════════════════════════════════════════════════════════════"
if [[ "$any_failed" -ne 0 ]]; then
    echo -e "${RED}${BOLD}COMMIT BLOCKED${RESET}: GlassWorm scan detected suspicious content."
    echo "Fix the issues above before committing."
    exit 1
fi

echo -e "${GREEN}${BOLD}All GlassWorm checks passed.${RESET} Proceeding with commit."
exit 0
